<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>User Register Profile</title>
</head>

<body style="margin:0;
font-family:Arial;
background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);
display:flex;
justify-content:center;
align-items:center;
height:100vh;">

<div style="
background:#1e1e2f;
padding:35px;
border-radius:12px;
width:380px;
text-align:center;
box-shadow:0 20px 50px rgba(0,0,0,0.6);
color:white;">

<h1 style="color:#ff4d4d;margin-bottom:20px;">
User Register Profile
</h1>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Name:</span>
<%= user.name %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Gender:</span>
<%= user.gender %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">DOB:</span>
<%= user.dob %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Father's Name:</span>
<%= user.fatherName %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Mother's Name:</span>
<%= user.motherName %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Phone:</span>
<%= user.phoneNumber %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Address:</span>
<%= user.address %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Email:</span>
<%= user.email %>
</p>

<p style="margin:10px 0;font-size:16px;">
<span style="color:#ff4d4d;font-weight:bold;">Password:</span>
<%= user.password %>
</p>

<a href="/register"
style="display:block;
margin-top:10px;
color:#ff4d4d;
text-decoration:none;">
Back to Register
</a>

<a href="/login"
style="display:block;
margin-top:10px;
color:#ff4d4d;
text-decoration:none;">
Back to Login
</a>

</div>

</body>
</html>